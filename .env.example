# =============================================================================
# Environment variable reference
# =============================================================================
# Copy this file to .env.local for local development:
#
#   cp .env.example .env.local
#
# .env.local is gitignored and never committed. Hosted environments
# (Preview, Staging, Production) are configured in Vercel — see
# docs/environment-variables.md for the full strategy.
# =============================================================================


# -----------------------------------------------------------------------------
# Database (required)
# -----------------------------------------------------------------------------
# Postgres connection string.
#
# Local:  points to the Docker Compose postgres container
# Hosted: configured per environment in Vercel (see docs/environment-variables.md)
#
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5433/react_data_dashboard?schema=public


# -----------------------------------------------------------------------------
# E2E test database (local only)
# -----------------------------------------------------------------------------
# Separate Postgres for Playwright e2e tests so they don't trample data
# synced into the dev DB by `npm run sync:trades`. Used by:
#   - e2e/global-setup.ts (DB reset + fixture insert before tests run)
#   - playwright.config.ts (DATABASE_URL override for the spawned dev server)
#
# `docker compose up -d` starts both Postgres containers (dev on 5433, test
# on 5434). CI points both DATABASE_URL and TEST_DATABASE_URL at the same
# Postgres service — there's no dev data to preserve.
#
TEST_DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5434/react_data_dashboard?schema=public


# -----------------------------------------------------------------------------
# Server port (optional)
# -----------------------------------------------------------------------------
# Port the Next.js dev server listens on. Defaults to 3000 if unset.
# Change this if port 3000 is already in use on your machine.
#
PORT=3000


# -----------------------------------------------------------------------------
# Playwright base URL (optional — leave UNSET in normal use)
# -----------------------------------------------------------------------------
# When unset, Playwright spawns its own dev server pointed at the test DB.
# Set this only if you want to point Playwright at a dev server you're
# running yourself (e.g. for debugging an e2e flake).
#
# PLAYWRIGHT_BASE_URL=http://127.0.0.1:3000


# -----------------------------------------------------------------------------
# Alpaca paper trading API (local only — never required in CI or hosted envs)
# -----------------------------------------------------------------------------
# Credentials for `npm run sync:trades`, which pulls trade history from a
# paper-trading account and writes it into the local Postgres. See
# docs/data-sync.md for setup steps and how to read the sync output.
#
# Get your keys from https://app.alpaca.markets/paper/dashboard/overview
# (sign up at https://app.alpaca.markets/signup if needed — no SSN required
# for paper-only access).
#
ALPACA_API_KEY_ID=
ALPACA_API_SECRET_KEY=
ALPACA_BASE_URL=https://paper-api.alpaca.markets
ALPACA_TRADER_NAME=Alpaca Paper
