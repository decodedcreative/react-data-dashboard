# =============================================================================
# Environment variable reference
# =============================================================================
# Copy this file to .env.local for local development:
#
#   cp .env.example .env.local
#
# .env.local is gitignored and never committed. Hosted environments
# (Preview, Staging, Production) are configured in Vercel — see
# docs/environment-variables.md for the full strategy.
# =============================================================================


# -----------------------------------------------------------------------------
# Database (required)
# -----------------------------------------------------------------------------
# Postgres connection string.
#
# Local:  points to the Docker Compose postgres container
# Hosted: configured per environment in Vercel (see docs/environment-variables.md)
#
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5433/react_data_dashboard?schema=public


# -----------------------------------------------------------------------------
# Server port (optional)
# -----------------------------------------------------------------------------
# Port the Next.js dev server listens on. Defaults to 3000 if unset.
# Change this if port 3000 is already in use on your machine.
#
PORT=3000


# -----------------------------------------------------------------------------
# Playwright base URL (optional)
# -----------------------------------------------------------------------------
# Base URL used by Playwright e2e tests. Must match PORT above.
# Only needed locally — CI sets this automatically via playwright.config.ts.
#
PLAYWRIGHT_BASE_URL=http://127.0.0.1:3000
