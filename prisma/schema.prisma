// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum TradeSide {
  buy
  sell
}

enum TradeStatus {
  filled
  pending
  cancelled
}

model Trade {
  id         String      @id @default(cuid())
  symbol     String
  side       TradeSide
  quantity   Decimal     @db.Decimal(19, 8)
  price      Decimal     @db.Decimal(19, 8)
  status     TradeStatus
  trader     String
  executedAt DateTime?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  @@index([symbol])
  @@index([executedAt])
}
